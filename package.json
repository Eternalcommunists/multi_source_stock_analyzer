{
  "name": "multi-source-stock-analyzer",
  "version": "1.0.0",
  "description": "A comprehensive stock analysis system utilizing multiple data sources including Tong Hua Shun iFinD, East Money API, akshare, and jqdatasdk",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "cd frontend && npm start",
    "dev:backend": "cd backend && pip install -r requirements.txt && python main.py",
    "build": "npm run build:frontend",
    "build:frontend": "cd frontend && npm run build",
    "start": "cd backend && python main.py",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint frontend/src --ext .ts,.tsx",
    "lint:fix": "eslint frontend/src --ext .ts,.tsx --fix",
    "format": "prettier --write \"frontend/src/**/*.{ts,tsx,json,css,md}\"",
    "prepare": "husky install",
    "docker:build": "docker build -t stock-analyzer .",
    "docker:deploy": "docker-compose up -d"
  },
  "keywords": [
    "stock",
    "analysis",
    "finance",
    "investment",
    "trading",
    "akshare",
    "ifind",
    "east-money",
    "jqdatasdk"
  ],
  "author": "SOLO",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/multi-source-stock-analyzer.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/multi-source-stock-analyzer/issues"
  },
  "homepage": "https://github.com/yourusername/multi-source-stock-analyzer#readme",
  "devDependencies": {
    "@types/node": "^18.15.11",
    "@types/react": "^18.0.31",
    "@types/react-dom": "^18.0.11",
    "@typescript-eslint/eslint-plugin": "^5.57.1",
    "@typescript-eslint/parser": "^5.57.1",
    "concurrently": "^8.0.1",
    "eslint": "^8.38.0",
    "eslint-config-react-app": "^7.0.1",
    "husky": "^8.0.3",
    "jest": "^29.5.0",
    "lint-staged": "^13.2.0",
    "prettier": "^2.8.7",
    "ts-jest": "^29.1.0",
    "typescript": "^4.9.5"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^4.9.5",
    "axios": "^1.3.4",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "moment": "^2.29.4",
    "chart.js": "^4.2.1",
    "react-chartjs-2": "^5.2.0",
    "zustand": "^4.3.6",
    "react-router-dom": "^6.10.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}